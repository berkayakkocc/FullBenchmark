<Window x:Class="FullBenchmark.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FullBenchmark.UI.ViewModels"
        xmlns:views="clr-namespace:FullBenchmark.UI.Views"
        xmlns:models="clr-namespace:FullBenchmark.UI.Models"
        Title="FullBenchmark" Height="780" Width="1280"
        MinHeight="640" MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgSurfaceBrush}">

    <!-- ViewModel → View mapping -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LiveMonitorViewModel}">
            <views:LiveMonitorView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RunBenchmarkViewModel}">
            <views:RunBenchmarkView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CompareViewModel}">
            <views:CompareView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>

        <!-- Nav item button style with selection DataTrigger -->
        <Style x:Key="NavItemStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="Foreground"      Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="14,10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,2">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource AccentSubtleBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSubtleBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource TextAccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══ NAVIGATION RAIL ══════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource BgNavRailBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Brand -->
                <Border DockPanel.Dock="Top"
                        Padding="20,24,20,18"
                        BorderBrush="{StaticResource SeparatorBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="FullBenchmark"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="{StaticResource TextAccentBrush}" />
                        <TextBlock Text="System Performance Suite"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Border>

                <!-- Version footer -->
                <Border DockPanel.Dock="Bottom"
                        Padding="20,12"
                        BorderBrush="{StaticResource SeparatorBrush}"
                        BorderThickness="0,1,0,0">
                    <TextBlock Text="v1.0  ·  .NET 9"
                               Style="{StaticResource MutedText}"
                               HorizontalAlignment="Center" />
                </Border>

                <!-- Nav items -->
                <ItemsControl ItemsSource="{Binding NavItems}" Margin="10,14,10,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:NavigationItem}">
                            <Button Style="{StaticResource NavItemStyle}"
                                    Command="{Binding DataContext.NavigateToCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="15"
                                               Width="22"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding Foreground,
                                                   RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Text="{Binding Label}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding Foreground,
                                                   RelativeSource={RelativeSource AncestorType=Button}}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- ══ CONTENT AREA ═════════════════════════════════════════════════ -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentViewModel}"
                        Focusable="False" />
    </Grid>
</Window>
