<UserControl x:Class="FullBenchmark.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgSurfaceBrush}">

    <ScrollViewer>
        <Grid Margin="32,28,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Settings" Style="{StaticResource H1}" />

            <!-- Benchmark config -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="BENCHMARK CONFIGURATION"
                               Style="{StaticResource MutedText}"
                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,16" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Left column -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Enabled Modules" Style="{StaticResource H3}" Margin="0,0,0,10" />
                            <CheckBox Content="CPU Benchmark"
                                      IsChecked="{Binding CpuEnabled}" Margin="0,4" />
                            <CheckBox Content="Memory Benchmark"
                                      IsChecked="{Binding MemoryEnabled}" Margin="0,4" />
                            <CheckBox Content="Disk Benchmark"
                                      IsChecked="{Binding DiskEnabled}" Margin="0,4" />
                            <CheckBox Content="GPU Benchmark (not yet available)"
                                      IsChecked="{Binding GpuEnabled}" IsEnabled="False"
                                      Opacity="0.4" Margin="0,4" />

                            <TextBlock Text="Disk Settings" Style="{StaticResource H3}" Margin="0,20,0,10" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Test file size (MB)"
                                           Style="{StaticResource StatLabel}" />
                                <TextBox  Grid.Row="0" Grid.Column="1"
                                          Text="{Binding DiskFileSizeMb, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Temp directory"
                                           Style="{StaticResource StatLabel}" />
                                <TextBox  Grid.Row="2" Grid.Column="1"
                                          Text="{Binding DiskTempPath, UpdateSourceTrigger=PropertyChanged}"
                                          IsReadOnly="False" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Cleanup after test"
                                           Style="{StaticResource StatLabel}" />
                                <CheckBox Grid.Row="4" Grid.Column="1"
                                          IsChecked="{Binding DiskCleanup}" />
                            </Grid>
                        </StackPanel>

                        <!-- Right column -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Duration" Style="{StaticResource H3}" Margin="0,0,0,10" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="10" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU run (seconds)"
                                           Style="{StaticResource StatLabel}" />
                                <TextBox  Grid.Row="0" Grid.Column="1"
                                          Text="{Binding CpuRunSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Memory run (seconds)"
                                           Style="{StaticResource StatLabel}" />
                                <TextBox  Grid.Row="2" Grid.Column="1"
                                          Text="{Binding MemRunSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Warmup (seconds)"
                                           Style="{StaticResource StatLabel}" />
                                <TextBox  Grid.Row="4" Grid.Column="1"
                                          Text="{Binding WarmupSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Save row -->
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button Content="Save Settings" Style="{StaticResource PrimaryButton}"
                                Command="{Binding SaveCommand}" Margin="0,0,12,0" />
                        <Button Content="Reset Defaults" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ResetToDefaultsCommand}" />
                        <TextBlock Text="{Binding SaveStatus}"
                                   Style="{StaticResource SubText}"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Machine info -->
            <Border Grid.Row="4" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="MACHINE IDENTITY"
                               Style="{StaticResource MutedText}"
                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,14" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Machine Name" Style="{StaticResource StatLabel}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding MachineName}" Style="{StaticResource MonoText}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Machine ID"   Style="{StaticResource StatLabel}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding MachineId}"   Style="{StaticResource MonoText}" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Manufacturer" Style="{StaticResource StatLabel}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Manufacturer}" Style="{StaticResource StatValue}" />
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Model"        Style="{StaticResource StatLabel}" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Model}" Style="{StaticResource StatValue}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- About -->
            <Border Grid.Row="6" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="ABOUT" Style="{StaticResource MutedText}"
                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="App Version" Style="{StaticResource StatLabel}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AppVersion}" Style="{StaticResource StatValue}" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Runtime" Style="{StaticResource StatLabel}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DotNetVersion}" Style="{StaticResource MonoText}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
