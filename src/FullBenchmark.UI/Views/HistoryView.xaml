<UserControl x:Class="FullBenchmark.UI.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:conv="clr-namespace:FullBenchmark.UI.Converters"
             Background="{StaticResource BgSurfaceBrush}">

    <UserControl.Resources>
        <conv:ScoreToColorConverter        x:Key="ScoreToColor" />
        <conv:NullableScoreConverter       x:Key="NullScore" />
        <conv:DateTimeOffsetShortConverter x:Key="DateShort" />
    </UserControl.Resources>

    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="220" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Benchmark History" Style="{StaticResource H1}" />

        <!-- Trend chart -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Score Trend"
                           Style="{StaticResource H3}" Margin="0,0,0,10" />
                <lvc:CartesianChart Series="{Binding TrendSeries}"
                                   XAxes="{Binding TrendXAxis}"
                                   YAxes="{Binding TrendYAxis}"
                                   AnimationsSpeed="0:0:0.3"
                                   Background="Transparent"
                                   LegendPosition="Right" />
            </DockPanel>
        </Border>

        <!-- Session list -->
        <Border Grid.Row="4" Style="{StaticResource Card}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Sessions"
                           Style="{StaticResource H3}" Margin="0,0,0,10" />
                <ListView ItemsSource="{Binding Sessions}"
                          SelectedItem="{Binding SelectedSession}"
                          BorderThickness="0"
                          Background="Transparent">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Date" Width="180"
                                            DisplayMemberBinding="{Binding StartedAt, Converter={StaticResource DateShort}}" />
                            <GridViewColumn Header="Overall" Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding OverallScore, Converter={StaticResource NullScore}}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding OverallScore, Converter={StaticResource ScoreToColor}}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="CPU" Width="80"
                                            DisplayMemberBinding="{Binding CpuScore, Converter={StaticResource NullScore}}" />
                            <GridViewColumn Header="Memory" Width="80"
                                            DisplayMemberBinding="{Binding MemoryScore, Converter={StaticResource NullScore}}" />
                            <GridViewColumn Header="Disk" Width="80"
                                            DisplayMemberBinding="{Binding DiskScore, Converter={StaticResource NullScore}}" />
                            <GridViewColumn Header="Status" Width="100"
                                            DisplayMemberBinding="{Binding Status}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
