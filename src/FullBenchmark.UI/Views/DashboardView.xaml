<UserControl x:Class="FullBenchmark.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FullBenchmark.UI.Converters"
             Background="{StaticResource BgSurfaceBrush}">

    <UserControl.Resources>
        <conv:ScoreToColorConverter   x:Key="ScoreToColor" />
        <conv:ScoreToProgressConverter x:Key="ScoreToProgress" />
        <conv:NullToCollapsedConverter x:Key="NullToCollapsed" />
        <conv:BadgeToColorConverter   x:Key="BadgeToColor" />
        <conv:NullableScoreConverter  x:Key="NullScore" />
    </UserControl.Resources>

    <ScrollViewer>
        <Grid Margin="32,28,32,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Page header ─────────────────────────────────────────── -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Dashboard" Style="{StaticResource H1}" />
                <TextBlock Text="{Binding MachineName}"
                           Style="{StaticResource SubText}"
                           Margin="0,4,0,0" />
            </StackPanel>

            <!-- ── Score cards row ─────────────────────────────────────── -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Overall Score -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="OVERALL" Style="{StaticResource MutedText}"
                                   FontSize="10" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding OverallScore, StringFormat=F1}"
                                   FontSize="44" FontWeight="Bold"
                                   Foreground="{Binding OverallScore, Converter={StaticResource ScoreToColor}}"
                                   Margin="0,6,0,4" />
                        <TextBlock Text="{Binding OverallBadge}"
                                   Foreground="{Binding OverallBadge, Converter={StaticResource BadgeToColor}}"
                                   FontSize="12" FontWeight="SemiBold" />
                        <ProgressBar Value="{Binding OverallScore, Converter={StaticResource ScoreToProgress}}"
                                     Foreground="{Binding OverallScore, Converter={StaticResource ScoreToColor}}"
                                     Margin="0,10,0,0" Height="8" />
                        <TextBlock Text="{Binding LastRunDate}"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,6,0,0" FontSize="11" />
                    </StackPanel>
                </Border>

                <!-- CPU Score -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="CPU" Style="{StaticResource MutedText}"
                                   FontSize="10" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CpuScore, Converter={StaticResource NullScore}}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{Binding CpuScore, Converter={StaticResource ScoreToColor}}"
                                   Margin="0,6,0,4" />
                        <TextBlock Text="{Binding CpuModel}"
                                   Style="{StaticResource SubText}"
                                   TextTrimming="CharacterEllipsis" />
                        <ProgressBar Value="{Binding CpuScore, Converter={StaticResource ScoreToProgress}}"
                                     Foreground="{Binding CpuScore, Converter={StaticResource ScoreToColor}}"
                                     Margin="0,10,0,0" Height="6" />
                    </StackPanel>
                </Border>

                <!-- Memory Score -->
                <Border Grid.Column="4" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="MEMORY" Style="{StaticResource MutedText}"
                                   FontSize="10" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding MemoryScore, Converter={StaticResource NullScore}}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{Binding MemoryScore, Converter={StaticResource ScoreToColor}}"
                                   Margin="0,6,0,4" />
                        <TextBlock Text="{Binding RamTotal}"
                                   Style="{StaticResource SubText}" />
                        <ProgressBar Value="{Binding MemoryScore, Converter={StaticResource ScoreToProgress}}"
                                     Foreground="{Binding MemoryScore, Converter={StaticResource ScoreToColor}}"
                                     Margin="0,10,0,0" Height="6" />
                    </StackPanel>
                </Border>

                <!-- Disk Score -->
                <Border Grid.Column="6" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="DISK" Style="{StaticResource MutedText}"
                                   FontSize="10" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding DiskScore, Converter={StaticResource NullScore}}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{Binding DiskScore, Converter={StaticResource ScoreToColor}}"
                                   Margin="0,6,0,4" />
                        <TextBlock Text="{Binding StorageInfo}"
                                   Style="{StaticResource SubText}"
                                   TextTrimming="CharacterEllipsis" />
                        <ProgressBar Value="{Binding DiskScore, Converter={StaticResource ScoreToProgress}}"
                                     Foreground="{Binding DiskScore, Converter={StaticResource ScoreToColor}}"
                                     Margin="0,10,0,0" Height="6" />
                    </StackPanel>
                </Border>

                <!-- GPU Score -->
                <Border Grid.Column="8" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="GPU" Style="{StaticResource MutedText}"
                                   FontSize="10" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding GpuScore, Converter={StaticResource NullScore}}"
                                   FontSize="36" FontWeight="Bold"
                                   Foreground="{Binding GpuScore, Converter={StaticResource ScoreToColor}}"
                                   Margin="0,6,0,4" />
                        <TextBlock Text="{Binding GpuModel}"
                                   Style="{StaticResource SubText}"
                                   TextTrimming="CharacterEllipsis" />
                        <ProgressBar Value="{Binding GpuScore, Converter={StaticResource ScoreToProgress}}"
                                     Foreground="{Binding GpuScore, Converter={StaticResource ScoreToColor}}"
                                     Margin="0,10,0,0" Height="6" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── Lower row: system info + comparison ────────────────── -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- System info card -->
                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="SYSTEM INFORMATION"
                                   Style="{StaticResource MutedText}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Margin="0,0,0,12" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU" Style="{StaticResource StatLabel}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CpuModel}" Style="{StaticResource StatValue}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="RAM" Style="{StaticResource StatLabel}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RamTotal}" Style="{StaticResource StatValue}" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Storage" Style="{StaticResource StatLabel}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding StorageInfo}" Style="{StaticResource StatValue}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="GPU" Style="{StaticResource StatLabel}" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding GpuModel}" Style="{StaticResource StatValue}" />
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="OS" Style="{StaticResource StatLabel}" />
                            <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding OsName}" Style="{StaticResource StatValue}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Comparison card -->
                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="COMPARISON"
                                   Style="{StaticResource MutedText}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="{Binding ComparisonSummary}"
                                   Style="{StaticResource BodyText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />
                        <ItemsControl ItemsSource="{Binding NearbyDevices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="60" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding DeviceName}"
                                                       Style="{StaticResource BodyText}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding CpuModel}"
                                                       Style="{StaticResource SubText}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding OverallScore, StringFormat=F0}"
                                                   FontSize="18" FontWeight="Bold"
                                                   Foreground="{Binding OverallScore, Converter={StaticResource ScoreToColor}}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
