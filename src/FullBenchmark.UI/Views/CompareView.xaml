<UserControl x:Class="FullBenchmark.UI.Views.CompareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FullBenchmark.UI.Converters"
             Background="{StaticResource BgSurfaceBrush}">

    <UserControl.Resources>
        <conv:ScoreToColorConverter  x:Key="ScoreToColor" />
        <conv:NullableScoreConverter x:Key="NullScore" />
        <conv:NullToCollapsedConverter x:Key="NullToCollapsed" />
    </UserControl.Resources>

    <Grid Margin="32,28,32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Compare" Style="{StaticResource H1}" />
            <TextBlock Text="{Binding ComparisonSummary}"
                       Style="{StaticResource SubText}" Margin="0,4,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>

        <!-- Your machine card + percentile -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardElevated}">
                <StackPanel>
                    <TextBlock Text="YOUR MACHINE" Style="{StaticResource MutedText}"
                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding MyOverallScore, StringFormat=F1}"
                               FontSize="48" FontWeight="Bold"
                               Foreground="{Binding MyOverallScore, Converter={StaticResource ScoreToColor}}" />
                    <TextBlock Text="Overall Score" Style="{StaticResource SubText}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="PERCENTILE RANK" Style="{StaticResource MutedText}"
                               FontSize="10" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock FontSize="48" FontWeight="Bold"
                               Foreground="{Binding PercentileRank, Converter={StaticResource ScoreToColor}}"
                               Visibility="{Binding PercentileRank, Converter={StaticResource NullToCollapsed}}">
                        <Run Text="{Binding PercentileRank, StringFormat=F0}" /><Run Text="%" />
                    </TextBlock>
                    <TextBlock Text="Better than this % of devices" Style="{StaticResource SubText}" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Device list -->
        <Border Grid.Row="4" Style="{StaticResource Card}">
            <DockPanel>
                <!-- Filter bar -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="Filter:" Style="{StaticResource StatLabel}" Margin="0,0,8,0" />
                    <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" Margin="0,0,16,0" />
                    <TextBlock Text="Category:" Style="{StaticResource StatLabel}" Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              Width="140" />
                </StackPanel>

                <ListView ItemsSource="{Binding Devices}" BorderThickness="0" Background="Transparent">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Device" Width="200"
                                            DisplayMemberBinding="{Binding DeviceName}" />
                            <GridViewColumn Header="CPU" Width="200"
                                            DisplayMemberBinding="{Binding CpuModel}" />
                            <GridViewColumn Header="RAM (GB)" Width="80"
                                            DisplayMemberBinding="{Binding RamTotalGB, StringFormat=F0}" />
                            <GridViewColumn Header="Category" Width="110"
                                            DisplayMemberBinding="{Binding Category}" />
                            <GridViewColumn Header="Overall" Width="90">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding OverallScore, StringFormat=F0}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding OverallScore, Converter={StaticResource ScoreToColor}}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="CPU Score"  Width="90"
                                            DisplayMemberBinding="{Binding CpuScore, Converter={StaticResource NullScore}}" />
                            <GridViewColumn Header="Mem Score"  Width="90"
                                            DisplayMemberBinding="{Binding MemoryScore, Converter={StaticResource NullScore}}" />
                            <GridViewColumn Header="Disk Score" Width="90"
                                            DisplayMemberBinding="{Binding DiskScore, Converter={StaticResource NullScore}}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
